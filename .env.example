# Local dev config. Copy to .env (gitignored) and fill in — dev.sh loads it.
# Use shell syntax: KEY=value, no spaces around =, quote values with special chars.

# Indian residential proxy for Zepto calls (non-Indian IPs are geofenced).
# Use the http:// scheme — it's a plain HTTP proxy that CONNECT-tunnels to
# Zepto's HTTPS. Do NOT use https://.
#   PROXY_URL="http://user:pass@host:port"
# (SOCKS5 also works as socks5://… but needs httpx[socks].)
PROXY_URL=""

# Lift all local rate limits / budgets / radius cap. dev.sh already sets this,
# so you only need it here to override.
# DEV_MODE=1
